# ── Monitor de Compliance Empresarial — Variables de entorno ──────────────
# Copiar como .env y completar con valores reales

# Carpeta donde se guardan los JSON de alertas y normativa
DATA_DIR=data

# AFIP Web Services (opcional — para Due Diligence real)
# AFIP_CERT_PATH=certs/afip.crt
# AFIP_KEY_PATH=certs/afip.key
# AFIP_CUIT=20123456789

# Railway / deploy
PORT=8000

# CORS (dejar * para desarrollo, restringir en producción)
ALLOWED_ORIGINS=*

# ── Canal de Denuncias (scripts/canal_denuncias.py) ───────────────────────
# OBLIGATORIO en producción: si no se configuran, el servidor genera un PIN
# aleatorio en cada arranque y lo muestra en los logs — pero eso NO es
# apto para producción (cambia en cada redeploy). Configurar acá con
# valores fuertes y fijos.
PIN_CONSULTOR=cambiar_por_un_pin_fuerte
PIN_COMPLIANCE=cambiar_por_un_pin_fuerte
PIN_EXPIRA_DIAS=30        # el PIN en sí expira cada N días, default 30
SESSION_HOURS=8           # cada sesión dura N horas, default 8

# Persistencia de la base de denuncias — IMPORTANTE en Railway:
# el filesystem se resetea en cada deploy. Crear un Volume en Railway
# (Settings → Volumes → New Volume, montado en /data) y apuntar acá,
# ej. DENUNCIAS_DB_PATH=/data/denuncias.db
# DENUNCIAS_DB_PATH=data/denuncias.db

# ── Onboarding de clientes (scripts/onboarding_cliente.py) ────────────────
# Persistencia de las solicitudes recibidas — mismo caso que arriba,
# montar dentro del Volume si se quiere que sobrevivan a un redeploy.
# SUBMISSIONS_DIR=/data/submissions

# Notificaciones por email de nuevas solicitudes de onboarding.
# Sin SMTP_PASSWORD configurada, el envío de mail se salta en silencio
# (no rompe la app, pero no llegan las notificaciones).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ecosistematransparencia@gmail.com
SMTP_PASSWORD=            # App Password de Gmail — no la contraseña normal
EMAIL_DESTINO=ecosistematransparencia@gmail.com

# Notificaciones (opcional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# EMAIL_ALERT=compliance@empresa.com
